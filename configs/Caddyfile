# Caddyfile - static host for the uniapp blog (T14)
#
# Listens on 127.0.0.1:48080 only (LAN cannot reach), accepts ANY Host
# header (so cloudflared's `Host: blog.multilab.cc` requests route to
# this site).
#
# Why `http://:48080 { bind 127.0.0.1 }` instead of `http://127.0.0.1:48080`:
#   The shorter `http://127.0.0.1:48080` form is a tempting one-liner,
#   but Caddy v2 makes the host part of the site address ALSO a Host-
#   header matcher. So `http://127.0.0.1:48080` would (a) listen on
#   127.0.0.1 (good) but (b) only match requests whose Host header is
#   "127.0.0.1" (bad - cloudflared sends `Host: blog.multilab.cc`,
#   which then misses the site and Caddy returns 200 with empty body).
#   Splitting the two concerns: site address `http://:48080` accepts
#   any Host, `bind 127.0.0.1` restricts the actual listener interface.
#   Verified 2026-05-14 after a "200/0 bytes" regression chasing this.
#
# Why `http://` scheme prefix is required: Caddy v2 treats any non-:80
# site address as HTTPS by default and does TLS handshake. Without it
# plain-HTTP clients (cloudflared, curl) get 400 "HTTP request to
# HTTPS server".
#
# 48080 avoids 8080 (Tomcat / Jenkins / dev servers all common on 8080).
#
# How to run (foreground, dev):
#   tools\caddy.exe run --config configs\Caddyfile
# Working dir = repo root, so `root * site` resolves to G:\...\PersonalBlog\site.

{
	# Global options
	admin off
	auto_https off
}

http://:48080 {
	bind 127.0.0.1
	root * site
	root * site

	encode zstd gzip

	# Static-asset paths get strict serving: missing file -> real 404 (from
	# file_server's default behavior). We split asset paths from SPA route
	# paths so a stale image link doesn't silently render index.html bytes
	# (which the browser would mis-render as a broken image with no log).
	#
	# Important: these MUST be two separate `handle` blocks, NOT a single
	# `@matcher path /static/* /assets/*` with one handle. The named-matcher
	# form interacts oddly with file_server and ends up returning 200 for
	# missing files plus a corrupted Content-Type header.
	handle /static/* {
		file_server
	}
	handle /assets/* {
		file_server
	}

	# Everything else: SPA history fallback for Vue Router. /post/12,
	# /pages/post/post?id=12, /tag, etc. all land on /index.html and the
	# client-side router takes over.
	#
	# Note on Content-Type charset: file_server's MIME detection on
	# Windows returns "text/html; charset=utf-8", "text/xml; charset=utf-8",
	# and "application/json" (no explicit charset, but JSON is UTF-8 per
	# RFC 8259). All correct for our content. We deliberately do NOT
	# override Content-Type via `header` directives - `application/rss+xml`
	# trips Caddy's `+` parsing and corrupts the result.
	handle {
		try_files {path} /index.html
		file_server
	}

	# Access log. logs/ is at repo root, gitignored. Service mode (NSSM)
	# also redirects stdout, but having Caddy's structured access log is
	# nicer for traffic-pattern debugging.
	log {
		output file logs/blog-caddy-access.log {
			roll_size 10mb
			roll_keep 5
		}
		format json
	}
}
