# Caddyfile - static host for the uniapp blog (T14)
#
# Listens on http://:48080 — bind-all (loopback + every active LAN IP).
#
# Why bind-all instead of an explicit IP pair like
# `http://127.0.0.1:48080, http://<LAN_IP>:48080`:
#   1. Tested 2026-05-13: the explicit-pair form failed to serve from
#      the browser on Windows (operator reported the site was
#      unreachable while Caddy did start). `http://:48080` always works.
#      The dual-listener path seems to interact badly with Windows'
#      IPv4/IPv6 dual-stack socket behavior. Don't fight it - use the
#      form that works.
#   2. DHCP can change the LAN IP at any time. Hard-coding it here means
#      the file rots; bind-all stays correct.
#   3. The LAN IP belongs to the operator's machine; not committing it
#      keeps the repo clean of personal-machine state.
#
# Trade-off (same as any bind-all): any LAN device can reach
# http://<this-machine-LAN-IP>:48080/ directly, bypassing Cloudflare HTTPS.
# Acceptable for a home network; revisit if box ever joins an untrusted one.
#
# Why `http://` scheme prefix is required: Caddy v2 treats any non-:80
# site address as HTTPS by default and the listener does TLS handshake.
# Without it plain-HTTP clients (cloudflared, curl) get 400 "HTTP request
# to HTTPS server".
#
# 48080 avoids 8080 (Tomcat / Jenkins / dev servers all common on 8080).
#
# How to run (foreground, dev):
#   tools\caddy.exe run --config configs\Caddyfile
# Working dir = repo root, so `root * site` resolves to G:\...\PersonalBlog\site.

{
	# Global options
	admin off
	auto_https off
}

http://:48080 {
	root * site

	encode zstd gzip
	# (Earlier disabled while debugging the "content-length: 0 through
	# tunnel" issue. Re-enabled after confirming the root cause was
	# cloudflared's loopback origin handling, not compression - see the
	# header comment block. Cloudflare's edge re-compresses for clients
	# anyway, so leaving this on costs ~nothing and helps direct LAN curls.)

	# Static-asset paths get strict serving: missing file -> real 404 (from
	# file_server's default behavior). We split asset paths from SPA route
	# paths so a stale image link doesn't silently render index.html bytes
	# (which the browser would mis-render as a broken image with no log).
	#
	# Important: these MUST be two separate `handle` blocks, NOT a single
	# `@matcher path /static/* /assets/*` with one handle. The named-matcher
	# form interacts oddly with file_server and ends up returning 200 for
	# missing files plus a corrupted Content-Type header.
	handle /static/* {
		file_server
	}
	handle /assets/* {
		file_server
	}

	# Everything else: SPA history fallback for Vue Router. /post/12,
	# /pages/post/post?id=12, /tag, etc. all land on /index.html and the
	# client-side router takes over.
	#
	# Note on Content-Type charset: file_server's MIME detection on
	# Windows returns "text/html; charset=utf-8", "text/xml; charset=utf-8",
	# and "application/json" (no explicit charset, but JSON is UTF-8 per
	# RFC 8259). All correct for our content. We deliberately do NOT
	# override Content-Type via `header` directives - `application/rss+xml`
	# trips Caddy's `+` parsing and corrupts the result.
	handle {
		try_files {path} /index.html
		file_server
	}

	# Access log. logs/ is at repo root, gitignored. Service mode (NSSM)
	# also redirects stdout, but having Caddy's structured access log is
	# nicer for traffic-pattern debugging.
	log {
		output file logs/blog-caddy-access.log {
			roll_size 10mb
			roll_keep 5
		}
		format json
	}
}
