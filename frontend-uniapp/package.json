{
  "name": "personal-blog-uniapp",
  "version": "0.1.0",
  "private": true,
  "description": "Personal blog rewritten as uni-app H5 (Vue 3 + UnoCSS), self-hosted via Caddy + Cloudflare Tunnel at blog.multilab.cc",
  "type": "module",
  "scripts": {
    "dev:h5": "node scripts/uni-run.mjs",
    "build:h5": "node scripts/uni-run.mjs build",
    "typecheck": "vue-tsc --noEmit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-components": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-h5": "3.0.0-alpha-5000820260430001",
    "highlight.js": "^11.10.0",
    "marked": "^14.1.3",
    "minisearch": "^7.1.0",
    "pinia": "^2.1.0",
    "vue": "3.4.21"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.0",
    "@dcloudio/uni-cli-shared": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-stacktracey": "3.0.0-alpha-5000820260430001",
    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-5000820260430001",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^14.0.0",
    "typescript": "^5.4.0",
    "unocss": "^0.62.0",
    "vite": "5.2.8",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.0.0"
  }
}
